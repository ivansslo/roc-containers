# ══════════════════════════════════════════════════
# .gitignore — roc-containers
# ══════════════════════════════════════════════════

# ─── Secrets & Keys ──────────────────────────────
.keys
*.keys
config.env
.env
.env.*
!.env.example
hermes_keys

# ─── Data ────────────────────────────────────────
data-*/
.hermes/
chat_history.json
chat_*.json

# ─── Python ──────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
python3_venv/
venv/

# ─── Node ────────────────────────────────────────
node_modules/

# ─── OS / Editor ─────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ─── Logs ────────────────────────────────────────
*.log

# ─── Solace & Aiven ────────────────────────────
solace.env
.config/hermes/
SECRETS-MASTER.env

# ─── Backups ───────────────────────────────────
*.bak
*.bak*
*.old

# ─── Runtime clones (clone saat dipakai, bukan source) ──
apps/ai/roadfx-ai-stack/
apps/ai/modules/
apps/hermui/hermes-ui/
apps/clawdex/clawdex-mobile/
apps/maagba/maagba-repo/
apps/spwr/repo/
apps/hms/upstream/
**/data-root/
